class Solution:
    def maxKDistinct(self, nums: List[int], k: int) -> List[int]:
        nums.sort(reverse=True)
        choice = [nums[0]]
        count = k -1
        i = 1

        while count != 0 and i < len(nums):
            if nums[i] != nums[i-1]:
                choice.append(nums[i])
                count -= 1
            
            i += 1
    
        return choice
