class Solution:
    def maxKDistinct(self, nums: List[int], k: int) -> List[int]:
        nums.sort(reverse=True)
        choice = [nums[0]]
        
        # Começamos do índice 1, iterando até o final
        for i in range(1, len(nums)):
            # Se já pegamos 'k' elementos, paramos a busca (Early Stopping)
            if len(choice) == k:
                break
                
            # Adiciona apenas se for diferente do anterior
            if nums[i] != nums[i-1]:
                choice.append(nums[i])
                
        return choice
# usando set

class Solution:
    def maxKDistinct(self, nums: List[int], k: int) -> List[int]:
        # 1. Usamos um 'set' para remover todas as duplicatas (todos distintos)
        # Depois, Convertemos de volta para lista
        elementos_distintos = list(set(nums))
        
        # 2. Ordenamos em ordem decrescente.
        # Essa é a essência gulosa: colocar os maiores valores no topo.
        elementos_distintos.sort(reverse=True)
        
        # 3. Pegamos no máximo os 'k' primeiros elementos.
        # A notação de fatiamento (slicing) do Python lidará automaticamente 
        # com casos onde há menos de 'k' elementos distintos disponíveis.
        return  elementos_distintos[:k]
